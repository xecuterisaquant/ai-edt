__pycache__/
*.pyc
*.pyo
.Python

# Virtual environments
venv/
.venv/
env/

# Environment variables (never commit secrets)
.env

# Runtime output (kept in repo via .gitkeep, contents ignored)
logs/*.log
signals/*.jsonl

# SQLite database and WAL files — stay local, never commit
signals/*.db
signals/*.db-shm
signals/*.db-wal

# Watcher runtime state — local only
signals/seen_links.txt
signals/watcher_health.json

# IDE
.vscode/
.idea/

# Build / distribution
*.egg-info/
dist/
build/

# pytest cache
.pytest_cache/

# KB data files (JSON) — commit these; only exclude DB runtime files
# (signals/*.db is already excluded above)
# data/ SQLite is unused — no exclusion needed here; allow all data/ contents